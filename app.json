{
  "expo": {
    "name": "Solar Merge",
    "slug": "solar-merge",
    "scheme": "solar-merge",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.iskael.solarmerge"
    },
    "android": {
      "package": "com.iskael.solarmerge"
    },
    "web": {
      "bundler": "metro",
      "baseUrl": "/solar-merge"
    },
    "experiments": {
      "baseUrl": "/solar-merge"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~4411468910"
        }
      ]
    ]
  }
}