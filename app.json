{
  "expo": {
    "name": "Solar Merge",
    "slug": "solar-merge",
    "scheme": "solar-merge",
    "version": "1.0.9",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#000000"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.iskael.solarmerge",
      "versionCode": 18,
      "newArchEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "baseUrl": "/solar-merge"
    },
    "experiments": {
      "baseUrl": "/solar-merge"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-9833011672001766~1325845179",
          "iosAppId": "ca-app-pub-3940256099942544~4411468910"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.0.21",
            "enableMultiDex": true
          }
        }
      ],
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "456536b0-8248-42bb-9a7c-6c185a415132"
      }
    }
  }
}
