{
  "expo": {
    "name": "Solar Merge",
    "slug": "solar-merge",
    "scheme": "solar-merge",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.iskael.solarmerge"
    },
    "android": {
      "package": "com.iskael.solarmerge"
    },
    "web": {
      "bundler": "metro",
      "baseUrl": "/solar-merge"
    },
    "experiments": {
      "baseUrl": "/solar-merge"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~4411468910"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.24",
            "enableMultiDex": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "456536b0-8248-42bb-9a7c-6c185a415132"
      }
    }
  }
}